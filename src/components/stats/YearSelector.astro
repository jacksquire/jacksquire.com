---
interface Props {
  years: string[];
  defaultYear: string;
}

const { years, defaultYear } = Astro.props;
---

<div class="flex flex-wrap gap-2 mb-8">
  {
    years.map((year) => (
      <button
        class:list={[
          "year-btn px-4 py-2 text-sm font-medium rounded-full border transition-colors",
          year === defaultYear
            ? "border-blue-500 bg-blue-500/15 text-blue-400"
            : "border-zinc-800 text-zinc-400 hover:border-zinc-700 hover:text-zinc-300",
        ]}
        data-year={year}
      >
        {year}
      </button>
    ))
  }
</div>
