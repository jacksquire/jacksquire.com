---
interface Props {
  label: string;
  value: string | number;
  sublabel?: string;
  color?: string;
}

const { label, value, sublabel, color } = Astro.props;
---

<div class="bg-zinc-900 border border-zinc-800 rounded-lg p-5">
  <p class="text-sm text-zinc-500 mb-2">{label}</p>
  <p
    class="text-4xl font-mono font-bold text-zinc-100 stat-number"
    data-stat-value
    style={color ? `color: ${color}` : undefined}
  >
    {value}
  </p>
  {sublabel && <p class="text-xs text-zinc-500 mt-1">{sublabel}</p>}
</div>
