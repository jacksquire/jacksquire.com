---
import type { ComputedAchievement } from '../../types/achievement';
import ProgressBar from './ProgressBar.astro';

interface Props {
  achievement: ComputedAchievement;
}

const { achievement } = Astro.props;

// Tier badge colors
const tierColors = {
  bronze: 'bg-amber-900/30 text-amber-400 border-amber-400/20',
  silver: 'bg-zinc-600/30 text-zinc-300 border-zinc-400/20',
  gold: 'bg-yellow-900/30 text-yellow-400 border-yellow-400/20',
  legendary: 'bg-purple-900/30 text-purple-400 border-purple-400/20',
};
---

<div
  class:list={[
    'card',
    'relative',
    'transition-all duration-300',
    'hover:scale-[1.02]',
    !achievement.isUnlocked && 'grayscale opacity-60',
  ]}
  data-category={achievement.category}
>
  <!-- Lock Icon -->
  {!achievement.isUnlocked && (
    <div class="absolute top-3 right-3 text-lg opacity-40">
      🔒
    </div>
  )}

  <!-- Tier Badge -->
  <div class={`inline-block px-2 py-1 rounded text-xs font-medium border mb-3 ${tierColors[achievement.tier]} ${achievement.tier === 'legendary' ? 'gradient-text' : ''}`}>
    {achievement.tier.charAt(0).toUpperCase() + achievement.tier.slice(1)}
  </div>

  <!-- Content -->
  <div class="flex flex-col">
    <!-- Icon -->
    <div class="text-4xl mb-3">
      {achievement.icon}
    </div>

    <!-- Title -->
    <h3 class="text-lg font-heading font-bold mb-1">
      {achievement.title}
    </h3>

    <!-- Description -->
    <p class="text-text-muted text-sm mb-4">
      {achievement.description}
    </p>

    <!-- Progress Bar -->
    <ProgressBar progress={achievement.progress} isUnlocked={achievement.isUnlocked} />

    <!-- Stats Row -->
    <div class="mt-2 flex justify-between items-center text-xs">
      <span class="font-mono text-text-muted">
        {achievement.current} / {achievement.requirement}
      </span>
      {achievement.isUnlocked && (
        <span class="text-green-400 font-medium">
          ✓ Unlocked
        </span>
      )}
    </div>

    <!-- Unlocked Message -->
    {achievement.isUnlocked && achievement.unlockedMessage && (
      <p class="mt-3 text-xs text-primary/80 italic">
        {achievement.unlockedMessage}
      </p>
    )}
  </div>
</div>

<style>
  @media (max-width: 768px) {
    .card:hover {
      transform: none;
    }
  }
</style>
